PORT=5000
MONGODB_URI=mongodb://localhost:27017/forensicai
JWT_SECRET=your_jwt_secret_key_change_in_production
AI_PROVIDER=openai
AI_API_KEY=your_api_key_here
AI_MODEL=gpt-4
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2048
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5368709120
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
REDIS_URL=redis://127.0.0.1:6379
EVIDENCE_STORE_DIR=./evidence-store
WORKING_DIR=./tmp/processing
REPORT_EXPORT_DIR=./tmp/exports
EVIDENCE_ENCRYPTION_KEY=generate_32_byte_base64_or_64_hex_key
EVIDENCE_KEY_ID=evidence-key-YYYY-MM-DD
EVIDENCE_WORKER_CONCURRENCY=2
PYTHON_BIN=python
PARSER_MAX_RECORDS=5000
PARSER_TIMEOUT_MS=120000
ML_CONTAMINATION=0.15
ML_TIMEOUT_MS=120000
ML_MAX_OUTPUT_BYTES=52428800
